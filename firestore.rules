rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Categories — public read, authenticated admin write
    match /categories/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Matches — public read, authenticated admin write
    match /matches/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Won predictions — public read, authenticated admin write
    match /wonPredictions/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Notifications — public read, authenticated admin write
    match /notifications/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
